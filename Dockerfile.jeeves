FROM nvidia/cuda:12.9.1-cudnn-devel-ubuntu24.04 AS base

# Set environment variables
ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
# Vars for CUDA
ENV CUDA_HOME=/usr/local/cuda
ENV PATH=${CUDA_HOME}/bin:${PATH}
ENV LD_LIBRARY_PATH=$LD_LIBRARY_PATH:/usr/local/nvidia/lib:/usr/local/nvidia/lib64:/usr/lib/x86_64-linux-gnu

# Install system dependencies and Python
RUN apt-get update && \
    apt-get upgrade -y && \
    apt-get install -y --no-install-recommends \
        software-properties-common \
        ca-certificates \
        curl \
        gnupg \
        gnupg2 \
        lsb-release \
        wget && \
    # Add Docker’s official GPG key + apt repo
    install -m 0755 -d /etc/apt/keyrings && \
    curl -fsSL https://download.docker.com/linux/ubuntu/gpg -o /etc/apt/keyrings/docker.asc && \
    chmod a+r /etc/apt/keyrings/docker.asc && \
    . /etc/os-release && \
    printf '%s\n' \
        "Types: deb" \
        "URIs: https://download.docker.com/linux/ubuntu" \
        "Suites: ${UBUNTU_CODENAME:-$VERSION_CODENAME}" \
        "Components: stable" \
        "Signed-By: /etc/apt/keyrings/docker.asc" \
        > /etc/apt/sources.list.d/docker.sources && \
    # Add Nvidia key + repo
    apt-key del 7fa2af80 && \
    sed -i '/developer\.download\.nvidia\.com\/compute\/cuda\/repos/d' /etc/apt/sources.list.d/* && \
    sed -i '/developer\.download\.nvidia\.com\/compute\/machine-learning\/repos/d' /etc/apt/sources.list.d/* && \
    wget https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2404/x86_64/cuda-keyring_1.1-1_all.deb && \
    dpkg -i cuda-keyring_1.1-1_all.deb && \
    # Deadsnakes for alt python versions
    add-apt-repository ppa:deadsnakes/ppa && \
    # Needed for recent versions of yq that behave right from opensuse repo...
    VERSION=$(. /etc/os-release && echo $VERSION_ID) && \
    echo "deb http://download.opensuse.org/repositories/home:/alvistack/xUbuntu_${VERSION}/ /" > /etc/apt/sources.list.d/home:alvistack.list && \
    curl -fsSL https://download.opensuse.org/repositories/home:/alvistack/xUbuntu_${VERSION}/Release.key | gpg --dearmor > /etc/apt/trusted.gpg.d/home_alvistack.gpg && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
        git \
        bash \
        vim \
        nano \
        less \
        zsh \
        jq \
        yq \
        sudo \
        tmux \
        xclip \
        xsel \
        python3 \
        python3-pip \
        python3-venv \
        python3-dev \
        openssl \
        libnss3 \
        libatk-bridge2.0-0 \
        libdrm2 \
        libxkbcommon0 \
        libxcomposite1 \
        libxdamage1 \
        libxrandr2 \
        libgbm1 \
        libxss1 \
        libasound2t64 \
        # Docker
        docker-ce \
        docker-ce-cli \
        containerd.io \
        docker-buildx-plugin \
        docker-compose-plugin \
        # replace docker overlyfs for the in-container docker runtime to work
        fuse-overlayfs \
        # Nvidia container toolkit 
        nvidia-container-toolkit && \
    # Configure container runtime
    nvidia-ctk runtime configure --runtime=docker && \
    apt-get autoremove -y && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# ============================================================================
# Create Python venv and add to PATH
# ============================================================================
RUN python3 -m venv /opt/venv

# Update PATH to prioritize venv python instead of system python
ENV PATH="/opt/venv/bin:${PATH}"

# Upgrade pip and other utils in venv
RUN /opt/venv/bin/pip install --upgrade --force-reinstall --ignore-installed \
        pip \
        setuptools \
        wheel \
        ninja \
        meson \
        build

# Install latest Node.js LTS
RUN curl -fsSL https://deb.nodesource.com/setup_lts.x | bash - && \
    apt-get install -y --no-install-recommends \
        nodejs && \
    npm install -g npm@latest pnpm && \
    npm cache clear --force && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

FROM base AS opencode-builder
# Manual versioning since we're building from source...
ENV OPENCODE_VERSION=0.0.0-jeeves
# Env var to toggle desktop app build inclusion
ARG BUILD_DESKTOP
ENV BUILD_DESKTOP=$BUILD_DESKTOP


# Opencode requires bun for building/development but not necessarily runtime, so install it on this layer only
# Opencode is a bit finnicky with bun versions, so you may need to do a test build and see which bun version
# it is expecting and pin it below for the build to work.
RUN npm install -g bun@latest && \
    npm cache clear --force

RUN git config --global http.postBuffer 524288000 \
    && git config --global http.version HTTP/1.1

# Clone repo
RUN git clone --depth=1 --recurse-submodules --shallow-submodules --remote-submodules https://github.com/anomalyco/opencode.git /app/opencode \
    && chmod -R 777 /app/opencode

WORKDIR /app/opencode

# Some branding overrides, just because...
RUN sed -i 's/"productName": "OpenCode"/"productName": "OpenCode Jeeves"/g' /app/opencode/packages/desktop/src-tauri/tauri.prod.conf.json
RUN sed -i 's/"identifier": "ai.opencode.desktop"/"identifier": "ai.opencode.desktop.jeeves"/g' /app/opencode/packages/desktop/src-tauri/tauri.prod.conf.json

# CLI/TUI/WebUI build
RUN bun install
RUN ./packages/opencode/script/build.ts

RUN \
    if [  "$BUILD_DESKTOP" = "true" ]; then \
        echo "BUILD_DESKTOP env variable is set. Running opencode desktop build step."; \
        # Install additional deps \
        apt update; \
        apt install -y  --no-install-recommends \
            libwebkit2gtk-4.1-dev \
            build-essential \
            curl \
            wget \
            file \
            libxdo-dev \
            libssl-dev \
            libayatana-appindicator3-dev \
            librsvg2-dev \
            rustup \
            # For win desktop \
            lld \
            llvm \
            nsis \
            clang \
            pkg-config \
            libglib2.0-dev \
            libgtk-3-dev \
            libgdk-pixbuf-2.0-dev \
            unzip; \
        # apt clean up \
        apt-get clean; \
        rustup default stable; \
        # For win desktop builder \
        cargo install --locked cargo-xwin; \
        rustup target add x86_64-pc-windows-msvc; \
        # Stage opencode bin sidecar pre-compile \
        mkdir -p /app/opencode/packages/desktop/src-tauri/sidecars; \
        cp /app/opencode/packages/opencode/dist/opencode-linux-x64/bin/opencode \
           /app/opencode/packages/desktop/src-tauri/sidecars/opencode-cli-x86_64-unknown-linux-gnu; \
        cp /app/opencode/packages/opencode/dist/opencode-windows-x64/bin/opencode.exe \
           /app/opencode/packages/desktop/src-tauri/sidecars/opencode-cli-x86_64-pc-windows-msvc; \
        # Add .exe extension for Windows sidecar (required by Tauri) \
        cp /app/opencode/packages/opencode/dist/opencode-windows-x64/bin/opencode.exe \
           /app/opencode/packages/desktop/src-tauri/sidecars/opencode-cli-x86_64-pc-windows-msvc.exe; \
        # run desktop builder (Linux) \
        cd /app/opencode/packages/desktop; \
        bun run tauri build --config src-tauri/tauri.prod.conf.json; \
        # run desktop builder (Windows) \
        bash -c \
            'export PATH="$HOME/.bun/bin:$HOME/.cargo/bin:$PATH" && \
            # source "$HOME/.cargo/env" && \
            bun run tauri build --config src-tauri/tauri.prod.conf.json \
                --runner cargo-xwin \
                --target x86_64-pc-windows-msvc'; \
        # final temp cleanup \
        rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*; \
    else \
        echo "Environment variable is not set. Skipping opencode desktop build step."; \
        # Create empty folders so the COPY command in the runtime stage doesn't fail \
        mkdir -p \
            /app/opencode/packages/desktop/src-tauri/target/release/bundle/deb \
            /app/opencode/packages/desktop/src-tauri/target/release/bundle/rpm \
            /app/opencode/packages/desktop/src-tauri/target/x86_64-pc-windows-msvc/release/bundle/nsis; \
    fi

WORKDIR /app/opencode

FROM base AS runtime

# ============================================================================
# Create non-root user with support for UID:GID mapping
# ============================================================================
ARG UID=1000
ARG GID=1000

# Create group and user, handling existing UID/GID
RUN if getent group ${GID}; then \
        groupmod -n jeeves $(getent group ${GID} | cut -d: -f1); \
    else \
        groupadd -r -g ${GID} jeeves; \
    fi && \
    if id -u ${UID} >/dev/null 2>&1; then \
        existing_user=$(id -nu ${UID}); \
        usermod -l jeeves -d /home/jeeves -m "$existing_user" 2>/dev/null || true; \
        groupmod -n jeeves "$existing_user" 2>/dev/null || true; \
    else \
        useradd -r -u ${UID} -g jeeves -m -s /bin/bash -d /home/jeeves jeeves; \
    fi && \
    #useradd -m -s /usr/bin/zsh jeeves && \
    echo '# zshrc (container default)' > /home/jeeves/.zshrc && \
    chown jeeves:jeeves /home/jeeves/.zshrc && \
    usermod -aG sudo jeeves && \
    echo "jeeves ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/jeeves && \
    chmod 0440 /etc/sudoers.d/jeeves

# ============================================================================
# Configure environment
# ============================================================================
ENV WORKSPACE=/proj
ENV HOME=/home/jeeves
ENV PYTHONUNBUFFERED=1

# Ensure venv is used for python/pip
ENV VIRTUAL_ENV=/opt/venv

# Install python packages
RUN /opt/venv/bin/pip install --upgrade --force-reinstall --ignore-installed \
        mcp-server-fetch \
        pyyaml

# Install Playwright browser and dependencies
USER jeeves

ENV PLAYWRIGHT_MCP_NO_SANDBOX=1
ENV PLAYWRIGHT_SKIP_BROWSER_CLEANUP=1

RUN sudo npm install -g @playwright/test && \
    npx playwright-core install-deps chromium firefox webkit && \
    npx playwright-core install --no-shell chromium firefox webkit

USER root


# ============================================================================
# Create and stage helper scripts
# ============================================================================

# Helper for tmux shell session create/reattach
RUN cat << 'EOF' > /usr/local/bin/jeeves-shell
#!/usr/bin/env sh
set -e

SESSION_NAME=main

# If already inside tmux, just start a normal shell
if [ -n "$TMUX" ]; then
  exec "${SHELL:-/bin/bash}"
fi

# Attach to existing session or create it
# The welcome message will be displayed by the shell's rc file
exec tmux new-session -A -s "$SESSION_NAME"
EOF

RUN chmod +x /usr/local/bin/jeeves-shell

# Welcome message and tmux hook for bash
# Can disable tmux with DISABLE_TMUX=1 and message with DISABLE_WELCOME=1
RUN cat << 'EOF' >> /etc/bash.bashrc

# --- opencode welcome message ---
# Skip if:
# - not an interactive TTY
# - explicitly disabled
if [ -t 1 ] && [ -z "$DISABLE_WELCOME" ]; then
  echo -e "\033[1;34m=============================================\033[0m"
  echo -e "\033[1;32mWelcome to Project Jeeves!\033[0m"
  echo -e "\033[1;34m=============================================\033[0m"
  echo -e "\033[0;37mWorkspace: \033[1;36m/proj\033[0m"
  echo -e "\033[0;37mOpenCode:  \033[1;36mRun 'opencode' to start\033[0m"
  echo -e "\033[0;37mCLAUDE:    \033[1;36mRun 'claude' to start\033[0m"
  echo -e "\033[1;34m=============================================\033[0m"
  echo
fi
# --- end opencode welcome message ---

# --- opencode tmux auto-attach ---
# Skip if:
# - not an interactive TTY
# - already inside tmux
# - explicitly disabled
if [ -t 1 ] && [ -z "$TMUX" ] && [ -z "$DISABLE_TMUX" ]; then
  exec /usr/local/bin/jeeves-shell
fi
# --- end opencode tmux auto-attach ---

EOF

# Welcome message and tmux hook for zsh
# Can disable tmux with DISABLE_TMUX=1 and message with DISABLE_WELCOME=1
RUN cat << 'EOF' >> /etc/zsh/zshrc

# --- opencode welcome message ---
# Skip if:
# - not an interactive TTY
# - explicitly disabled
if [[ -t 1 && -z "$DISABLE_WELCOME" ]]; then
  echo -e "\033[1;34m=============================================\033[0m"
  echo -e "\033[1;32mWelcome to Project Jeeves!\033[0m"
  echo -e "\033[1;34m=============================================\033[0m"
  echo -e "\033[0;37mWorkspace: \033[1;36m/proj\033[0m"
  echo -e "\033[0;37mOpenCode:  \033[1;36mRun 'opencode' to start\033[0m"
  echo -e "\033[0;37mCLAUDE:    \033[1;36mRun 'claude' to start\033[0m"
  echo -e "\033[1;34m=============================================\033[0m"
  echo
fi
# --- end opencode welcome message ---

# --- opencode tmux auto-attach ---
# Skip if:
# - not an interactive TTY
# - already inside tmux
# - explicitly disabled
if [[ -t 1 && -z "$TMUX" && -z "$DISABLE_TMUX" ]]; then
  exec /usr/local/bin/jeeves-shell
fi
# --- end opencode tmux auto-attach ---

EOF

# And now for tmux config settings to make it behave like a proper terminal
# with history scrolling, copy-paste, etc.
RUN cat << 'EOF' >> /home/jeeves/.tmux.conf
# 1. Enable Mouse Support (enables scrolling terminal output)
set -g mouse on

# 2. Enable System Clipboard (OSC 52 support)
set -s set-clipboard on

# 3. Fix ESC Lag (lowers delay from 500ms to 10ms)
set -sg escape-time 10

# 4. Optional: Increase history for more scrollback
set -g history-limit 50000

# Fix colors
set -g default-terminal "screen-256color"
EOF

# ============================================================================
# Setup directories with proper permissions
# ============================================================================
RUN mkdir -p /proj && \
    chown -R jeeves:jeeves /proj && \
    chown -R jeeves:jeeves /home/jeeves && \
    chown -R jeeves:jeeves /opt/venv

# Switch to non-root user
USER jeeves

# env to hopefully push the `~/.claude.json` into the `~/.claude` folder for easier volume mapping
ENV CLAUDE_CONFIG_DIR="/home/jeeves/.claude"

# Build argument to control Claude Code installation
ARG INSTALL_CLAUDE_CODE
ENV INSTALL_CLAUDE_CODE=${INSTALL_CLAUDE_CODE:-false}

# Since claude has no build stage, run the installer script (conditional)
RUN if [ "$INSTALL_CLAUDE_CODE" = "true" ]; then \
        echo "Installing Claude Code..."; \
        curl -fsSL https://claude.ai/install.sh | bash -s -- latest; \
        # Add ~/.local/bin to path, since this is where claude installs and we can't change that, \
        # we'll manually move the bin ourselves to a more standard location... \
        sudo cp "$(readlink -f "$HOME/.local/bin/claude")" /usr/local/bin/claude && \
        sudo chmod 755 /usr/local/bin/claude; \
    else \
        echo "Claude Code installation skipped (INSTALL_CLAUDE_CODE is not 'true')"; \
    fi

#Linux CLI Binary, copied to path location as well since we will use it interactively
COPY --from=opencode-builder ["/app/opencode/packages/opencode/dist/opencode-linux-x64/bin/opencode", "/usr/local/bin/opencode"]
COPY --from=opencode-builder ["/app/opencode/packages/opencode/dist/opencode-linux-x64/bin/opencode", "/app/dist/opencode"]
# Linux GUI (Debian/Ubuntu Package)
COPY --from=opencode-builder ["/app/opencode/packages/desktop/src-tauri/target/release/bundle/deb/OpenCode Jeeves*.deb", "/app/dist/"]
# Linux GUI (RPM/Fedora Package)
COPY --from=opencode-builder ["/app/opencode/packages/desktop/src-tauri/target/release/bundle/rpm/OpenCode Jeeves*.rpm", "/app/dist/"]
# Windows GUI (Standalone Executable)
COPY --from=opencode-builder ["/app/opencode/packages/desktop/src-tauri/target/x86_64-pc-windows-msvc/release/bundle/nsis/OpenCode Jeeves*.exe", "/app/dist/"]

RUN sudo chmod 0755 /usr/local/bin/opencode

# ============================================================================
# Stage OOB configuration files before bind mounts would hide them
# ============================================================================
# Create OOB config staging directory
RUN sudo mkdir -p /opt/oob-config/.config/opencode /opt/oob-config/.claude

# Copy any existing config files generated by installations to OOB staging
RUN if [ -d "/home/jeeves/.config/opencode" ] && [ "$(ls -A /home/jeeves/.config/opencode 2>/dev/null)" ]; then \
        sudo cp -r /home/jeeves/.config/opencode/* /opt/oob-config/.config/opencode/; \
    fi

RUN if [ -d "/home/jeeves/.claude" ] && [ "$(ls -A /home/jeeves/.claude 2>/dev/null)" ]; then \
        sudo cp -r /home/jeeves/.claude/* /opt/oob-config/.claude/; \
    fi

# Make sure the OOB config directories have proper permissions
RUN sudo chown -R jeeves:jeeves /opt/oob-config

# ============================================================================
# Install PRD Creator Toolkit
# ============================================================================
# Switch to root for installation
USER root

# Create directory for jeeves supplementary tools
RUN mkdir -p /opt/jeeves/

# Copy helper scripts
COPY jeeves/bin /usr/local/bin/

# Copy PRD Creator files
COPY jeeves/PRD /opt/jeeves/PRD/
# Copy Deepest Thinking files
COPY jeeves/Deepest-Thinking /opt/jeeves/Deepest-Thinking/
# Copy Ralph ref files
COPY jeeves/Ralph /opt/jeeves/Ralph/

# Set permissions
RUN chmod -R +x /usr/local/bin/ && \
    chown -R jeeves:jeeves /opt/jeeves

# Switch back to jeeves user
USER jeeves

# ============================================================================
# Create embedded entrypoint script for config initialization
# ============================================================================
# Temp switch to root
USER root

RUN sudo cat << 'EOF' > /usr/local/bin/entrypoint.sh
#!/bin/bash
set -euo pipefail

# Flag to track if Docker engine was started by this script
DOCKER_ENGINE_STARTED=false

# Function to check if ENABLE_DIND is a truthy value
is_dind_enabled() {
  local value="${ENABLE_DIND:-}"
  # Convert to lowercase for case-insensitive check
  value=$(echo "$value" | tr '[:upper:]' '[:lower:]')
  
  # Truthy values: true, 1, yes, on
  if [[ "$value" == "true" || "$value" == "1" || "$value" == "yes" || "$value" == "on" ]]; then
    return 0 # true
  fi
  
  return 1 # false
}

# Function to start docker engine and wait until it's fully running
start_docker_engine() {
  # Check if DIND is enabled
  if ! is_dind_enabled; then
    echo "Docker Engine (dockerd) startup skipped: ENABLE_DIND is not set to a truthy value"
    return 0
  fi

  # If it's already up, don't start a second daemon
  if docker info >/dev/null 2>&1; then
    echo "Docker Engine (dockerd) is already running"
    return 0
  fi

  echo "Starting Docker Engine (dockerd)..."

  # Clean up any stale pid/socket (common after unclean shutdown)
  sudo find /run /var/run -iname 'docker*.pid' -delete || true

  sudo mkdir -p /var/lib/docker /var/run /var/log /etc/docker

  # Custom daemon.json to use the nvidia runtime and fuse-overlayfs storage driver
  echo '{"storage-driver":"fuse-overlayfs","runtimes":{"nvidia":{"path":"nvidia-container-runtime","runtimeArgs":[]}}}' | sudo tee /etc/docker/daemon.json > /dev/null

  # Permissions reset on log folder - needed to permit the startup to execute
  sudo chmod -R 755 /var/log/

  # Start dockerd in the background (unix socket only)
  # --group jeeves makes /var/run/docker.sock accessible to the jeeves user
  sudo sh -c "dockerd \
    --host=unix:///var/run/docker.sock \
    --data-root=/var/lib/docker \
    --group=jeeves \
    ${DOCKERD_ARGS:-} \
    >/var/log/dockerd.log 2>&1" &

  DOCKERD_PID=$!
  DOCKER_ENGINE_STARTED=true

  # Permissions reset
  sudo chmod -R 755 /var/lib/docker /var/log/

  # Wait until the daemon is responsive
  echo "Waiting for dockerd to be ready..."
  for i in $(seq 1 60); do
    if docker info >/dev/null 2>&1; then
      echo "dockerd is up."
      return 0
    fi
    sleep 1
  done

  echo "ERROR: dockerd did not become ready in time." >&2
  sudo tail -n 200 /var/log/dockerd.log >&2 || true
  exit 1
}

# Function do to a clean docker shutdown on container halt signal
cleanup() {
  if [ "$DOCKER_ENGINE_STARTED" = true ] && [ -n "${DOCKERD_PID:-}" ] && sudo kill -0 "${DOCKERD_PID}" 2>/dev/null; then
    echo "Stopping dockerd..."
    sudo kill "${DOCKERD_PID}" || true
  fi
}

# Function to copy OOB config if directory is empty
copy_oob_if_empty() {
    local target_dir="$1"
    local oob_dir="$2"
    local config_name="$3"

    if [ -d "$target_dir" ]; then
        # Check if directory is empty (no files or subdirectories)
        if [ -z "$(ls -A "$target_dir" 2>/dev/null)" ]; then
            echo "Initializing $config_name configuration directory: $target_dir"
            if [ -d "$oob_dir" ] && [ "$(ls -A "$oob_dir" 2>/dev/null)" ]; then
                sudo cp -r "$oob_dir"/* "$target_dir"/
                sudo chown -R jeeves:jeeves "$target_dir"
                echo "Copied OOB $config_name configuration files"
            else
                echo "Warning: OOB $config_name configuration directory $oob_dir is empty or does not exist"
            fi
        else
            echo "$config_name configuration directory already contains files, skipping initialization"
        fi
    else
        echo "Warning: $config_name configuration directory $target_dir does not exist"
    fi
}

# Function to safely create configuration files without overwriting
safe_create_config() {
    local target_file="$1"
    local content="$2"
    
    if [ ! -f "$target_file" ]; then
        echo "Creating $target_file with agent configuration..."
        echo "$content" > "$target_file"
        echo "✅ Created: $target_file"
    else
        echo "⚠️  $target_file already exists - preserving existing configuration"
        echo "ℹ️  Existing file contents not modified"
    fi
}

# Docker cleanup trap
trap cleanup EXIT

# Start Docker first
start_docker_engine

# Initialize configuration directories
copy_oob_if_empty "/home/jeeves/.config/opencode" "/opt/oob-config/.config/opencode" "OpenCode"
copy_oob_if_empty "/home/jeeves/.claude" "/opt/oob-config/.claude" "Claude"
sudo chown -R jeeves:jeeves /home/jeeves

# Auto-install some skills at the user level that should be useful
# See: https://github.com/kamalnrf/claude-plugins
#      https://www.reddit.com/r/opencodeCLI/comments/1pzni8k/45000_public_claude_skills_are_now/

echo "Installing skills-discovery for opencode and claude code..."
# https://claude-plugins.dev/skills/@Kamalnrf/claude-plugins/skills-discovery
npx skills-installer install @Kamalnrf/claude-plugins/skills-discovery --client opencode
npx skills-installer install @Kamalnrf/claude-plugins/skills-discovery --client claude-code

echo "Installing using-superpowers for opencode and claude code..."
# https://claude-plugins.dev/skills/@obra/superpowers/using-superpowers
npx skills-installer install @obra/superpowers/using-superpowers --client opencode
npx skills-installer install @obra/superpowers/using-superpowers --client claude-code

# Additional setup - tool preferences and amplify skill usage
echo "Configuring agent preferences and tool settings..."

# Create OpenCode AGENTS.md for auto-loading and tool preferences
OPENCODE_AGENTS_MD="/home/jeeves/.config/opencode/AGENTS.md"
OPENCODE_CONFIG_CONTENT="# OpenCode Agent Configuration

## Automatic Skill Loading
At the beginning of every conversation, automatically invoke: skill using-superpowers
Since skills are only loaded at startup, if a new skill is installed as part of your working process, pause and ask the user to restart the application before continuing (usually '/exit' will close the application, and the user can resume the session via the --continue CLI option)

## Web Search Tool Preference
When performing web searches, prefer searxng tools over exa tools:
- Use searxng_searxng_web_search for general web searches
- Use searxng_web_url_read for content extraction  
- Only use exa tools as fallback when searxng is unavailable

## Containerized Limitations
You are running in a Docker container.  While you have full access to the /proj directory, you will have limited access to any other folder
You may ask the user to install additional Ubuntu packages if needed, but you cannot do so yourself
You do NOT have access to the docker engine, CLI, API, or socket - do not attempt any docker commands (build, compose, rm, ls, ps, etc.)
"


safe_create_config "$OPENCODE_AGENTS_MD" "$OPENCODE_CONFIG_CONTENT"

# Create Claude Code CLAUDE.md for equivalent functionality  
CLAUDE_CONFIG_CONTENT="# Claude Code Configuration

## Automatic Skill Loading
At the beginning of every conversation, automatically invoke: skill using-superpowers
Since skills are only loaded at startup, if a new skill is installed as part of your working process, pause and ask the user to restart the application before continuing (usually '/exit' will close the application, and the user can resume the session via the --continue CLI option)

## Web Search Tool Preference  
When performing web searches, prefer searxng tools over exa tools:
- Use searxng_searxng_web_search for general web searches
- Use searxng_web_url_read for content extraction
- Only use exa tools as fallback when searxng is unavailable

## Containerized Limitations
You are running in a Docker container.  While you have full access to the /proj directory, you will have limited access to any other folder
You may ask the user to install additional Ubuntu packages if needed, but you cannot do so yourself
You do NOT have access to the docker engine, CLI, API, or socket - do not attempt any docker commands (build, compose, rm, ls, ps, etc.)
"

CLAUDE_MD="/home/jeeves/.claude/CLAUDE.md"
safe_create_config "$CLAUDE_MD" "$CLAUDE_CONFIG_CONTENT"

echo "Agent configuration completed successfully!"

echo "Attempting to resolve dependencies required be installed skills..."
echo "Any resolved dependencies will attempt to be installed automatically."
if [ -x /usr/local/bin/install-skill-deps.sh ]; then                                                                                                                                                            
     /usr/local/bin/install-skill-deps.sh --verbose                                                                                                                                                              
fi
echo "Dependency resolution and install complete."
echo "Note: This process works by attempting to parse out deps from skill MD files.  Since this isn't required or standardized, detection and/or installation may silently fail, requiring manual installation."

# Configure git user identity from host environment
if [ -n "$GIT_AUTHOR_NAME" ]; then
    echo "Setting git user.name to: $GIT_AUTHOR_NAME"
    git config --global user.name "$GIT_AUTHOR_NAME"
fi
if [ -n "$GIT_AUTHOR_EMAIL" ]; then
    echo "Setting git user.email to: $GIT_AUTHOR_EMAIL"
    git config --global user.email "$GIT_AUTHOR_EMAIL"
fi

# If no arguments provided, default to opencode web
if [ $# -eq 0 ]; then
    set -- opencode web --hostname 0.0.0.0 --port 3333
fi

# Execute the command
exec "$@"
EOF

RUN chmod +x /usr/local/bin/entrypoint.sh

# Switch back to runtime user and re-fix home permissions
USER jeeves
RUN sudo chown -R jeeves:jeeves /home/jeeves

# Set working directory
WORKDIR /proj

EXPOSE 3333
# ============================================================================
# Entry point: Not used
# Start cmd: Initialize config directories if empty, 
#            then start docker and run the Web UI
# ============================================================================
ENTRYPOINT []
CMD ["/usr/local/bin/entrypoint.sh"]
