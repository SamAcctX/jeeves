# Force LF line endings for all text files checked into this repo.
# This prevents Windows git clients from converting to CRLF, which
# breaks shell script shebangs and causes container start failures.

# Default: auto-detect text files and normalise to LF
* text=auto eol=lf

# Explicitly LF for every text type used in this repo
*.sh        text eol=lf
*.py        text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.conf      text eol=lf
*.template  text eol=lf
*.gitignore text eol=lf
*.ps1       text eol=crlf
Dockerfile* text eol=lf
LICENSE     text eol=lf

# Binary files — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
*.tar  binary
*.gz   binary
*.deb  binary
*.rpm  binary
*.exe  binary
